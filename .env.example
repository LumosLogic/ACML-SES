PORT=3000

# AWS SES SMTP
SES_SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SES_SMTP_PORT=465
SES_SMTP_USER=
SES_SMTP_PASS=

# AWS Credentials (for CloudWatch)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# SES Config
SES_CONFIG_SET=
SES_DEFAULT_FROM=no-reply@yourdomain.com
SES_SEND_RATE=14
ALLOWED_FROM_DOMAINS=yourdomain.com
MAX_RECIPIENTS=10000
BULK_THRESHOLD=50

# Redis
REDIS_URL=redis://localhost:6379

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# API Keys
API_KEY=
ADMIN_KEY=

# Unsubscribe
UNSUBSCRIBE_BASE_URL=https://yourdomain.com
UNSUBSCRIBE_SECRET=
